#!/usr/bin/env bash
# Agentic Resource Discovery End-to-End Conformance Demo Runner
# Validates mock manifests, starts the mock registry API, and runs active probes.

# Set strict shell settings
set -euo pipefail

# Colors for beautiful output
BOLD="\033[1m"
GREEN="\033[32m"
RED="\033[31m"
CYAN="\033[36m"
RESET="\033[0m"

# Get script directory path
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$(dirname "$DIR")")"

echo -e "${BOLD}${CYAN}=== Starting Agentic Resource Discovery Conformance Verification Demo ===${RESET}"

# 1. Verify manifest files
echo -e "\n${BOLD}[Step 1/3] Validating mock manifest files...${RESET}"
MANIFEST_STATUS=0
for manifest_file in "$PROJECT_ROOT"/conformance/examples/*.json; do
    echo -e "\n${CYAN}Testing file: $(basename "$manifest_file")${RESET}"
    "$PROJECT_ROOT/conformance/bin/conformance-test" manifest "$manifest_file" || MANIFEST_STATUS=1
done

if [ $MANIFEST_STATUS -eq 0 ]; then
    echo -e "  ${GREEN}✓ Step 1: All mock manifests are fully spec-compliant!${RESET}"
else
    echo -e "  ${RED}✗ Step 1: One or more mock manifests failed validation.${RESET}"
    exit 1
fi

# 2. Spawn example registry API server
echo -e "\n${BOLD}[Step 2/3] Starting Example Registry API server in background...${RESET}"
python3 "$PROJECT_ROOT/conformance/examples/registry-server.py" > /dev/null 2>&1 &
SERVER_PID=$!

# Set trap to ensure server is always killed on exit (even on shell errors or Ctrl+C)
cleanup() {
    echo -e "\n${BOLD}Cleaning up: Stopping background Example Registry API...${RESET}"
    kill "$SERVER_PID" 2>/dev/null || true
    wait "$SERVER_PID" 2>/dev/null || true
    echo -e "  ${GREEN}Background server stopped.${RESET}"
}
trap cleanup EXIT

# Give server a moment to initialize and bind
sleep 1.5

# 3. Validate live running registry server
echo -e "\n${BOLD}[Step 3/3] Probing and validating live example registry API...${RESET}"
"$PROJECT_ROOT/conformance/bin/conformance-test" registry "http://127.0.0.1:9010"
REGISTRY_STATUS=$?

if [ $REGISTRY_STATUS -eq 0 ]; then
    echo -e "  ${GREEN}✓ Step 3: Example registry API matches specification requirements!${RESET}"
else
    echo -e "  ${RED}✗ Step 3: Example registry API failed conformance test.${RESET}"
    exit 1
fi

echo -e "\n${BOLD}${GREEN}=== ALL CONFORMANCE CHECKS PASSED SUCCESSFUL ===${RESET}"
echo -e "Agentic Resource Discovery implementation is fully compliant."
exit 0
